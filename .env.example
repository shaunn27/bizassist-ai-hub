# Gemini AI Configuration (Google AI Studio)
# Production: keep secret in server environment only.
GEMINI_API_KEY=AIza...

# Optional default model (falls back to gemini-2.5-flash)
# GEMINI_MODEL=gemini-2.5-flash

# Optional browser fallback for local demos only
# VITE_GEMINI_API_KEY=AIza...
# VITE_GEMINI_MODEL=gemini-2.5-flash

# Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
# For server-side persistence (recommended)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback if service role is not set
# SUPABASE_ANON_KEY=your-anon-key
