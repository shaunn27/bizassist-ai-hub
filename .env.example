# Ilmu AI Configuration
# Production: keep secret in server environment only.
ILMU_API_KEY=sk-...

# Optional default model (falls back to ilmu-glm-5.1)
# ILMU_MODEL=ilmu-glm-5.1

# Optional browser fallback for local demos only
# VITE_ILMU_API_KEY=sk-...
# VITE_ILMU_BASE_URL=https://api.ilmu.ai/v1
# VITE_ILMU_MODEL=ilmu-glm-5.1

# Supabase configuration
SUPABASE_URL=https://your-project-ref.supabase.co
# For server-side persistence (recommended)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional fallback if service role is not set
# SUPABASE_ANON_KEY=your-anon-key
